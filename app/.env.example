# 出口成章 app provider 配置
# local: 使用本地启发式逻辑 + 可选本地 STT / LLM 快切
# http: 通过 HTTP 调用外部 STT / LLM 服务
CKCZ_PROVIDER=local

# 可选：复制为 .env.local 后再改；server 启动时会自动加载 .env / .env.local
# 当 CKCZ_PROVIDER=http 时启用
CKCZ_HTTP_BASE_URL=http://127.0.0.1:8000
CKCZ_HTTP_HEALTH_PATH=/health
CKCZ_HTTP_TRANSCRIBE_PATH=/transcribe
CKCZ_HTTP_POLISH_PATH=/polish
CKCZ_HTTP_TIMEOUT_MS=15000
CKCZ_HTTP_RETRIES=1

# 本地 STT（faster-whisper）
# 安装脚本：在 app/ 目录内执行 bash scripts/setup-local-stt.sh
# 建议将 CKCZ_STT_PYTHON 指向 .venv/bin/python
CKCZ_STT_PYTHON=python3
CKCZ_STT_MODEL=small
# 可选：若你已手动下载模型到本地目录，可直接绕过 HuggingFace 拉取
CKCZ_STT_MODEL_PATH=
CKCZ_STT_DEVICE=cpu
CKCZ_STT_COMPUTE_TYPE=int8
CKCZ_STT_TIMEOUT_MS=120000
CKCZ_BODY_LIMIT_MB=25

# 可选：本地 STT 失败时自动回退到 HTTP STT
CKCZ_STT_HTTP_BASE_URL=
CKCZ_STT_HTTP_HEALTH_PATH=/health
CKCZ_STT_HTTP_TRANSCRIBE_PATH=/transcribe
